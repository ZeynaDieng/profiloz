# Copier vers docker/.env.production puis adapter les secrets.

POSTGRES_USER=profiloz
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=profiloz

JWT_SECRET=change-me-in-production-use-64-char-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

HTTP_PORT=80
CORS_ORIGIN=http://localhost

# URL publique vue par le navigateur (via nginx)
NUXT_PUBLIC_APP_URL=http://localhost
NUXT_PUBLIC_API_BASE_URL=http://localhost/api/v1

# Réseau Docker interne — SSR Nuxt + Puppeteer (API → web, web → api)
APP_URL=http://web:3000
NUXT_API_INTERNAL_BASE_URL=http://api:3001/api/v1
# URL publique du front pour les redirections PayTech (navigateur)
PUBLIC_APP_URL=http://localhost

# --- Paiement PayTech (obligatoire pour /payments/checkout) ---
PAYTECH_API_KEY=
PAYTECH_API_SECRET=
PAYTECH_ENV=test
PAYTECH_IPN_URL=https://votre-domaine.sn/api/v1/payments/ipn

STRICT_PDF_READINESS=true
RUN_SEED=true
CRON_SECRET=change-me-cron-secret
