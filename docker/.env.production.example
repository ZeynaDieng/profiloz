# Copier vers docker/.env.production puis remplir les secrets.

POSTGRES_USER=profiloz
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=profiloz

JWT_SECRET=change-me-in-production-use-64-char-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

HTTP_PORT=80
CORS_ORIGIN=https://profiloz.com

NUXT_PUBLIC_APP_URL=https://profiloz.com
NUXT_PUBLIC_API_BASE_URL=https://profiloz.com/api/v1

APP_URL=http://web:3000
PDF_RENDER_INTERNAL_URL=http://web:3000
NUXT_API_INTERNAL_BASE_URL=http://api:3001/api/v1
PUBLIC_APP_URL=https://profiloz.com

# --- Paiement PayTech (obligatoire — sans ces clés, checkout = 503) ---
# Clés sandbox ou prod depuis https://paytech.sn (Paramètres > API & IPN)
PAYTECH_API_KEY=
PAYTECH_API_SECRET=
PAYTECH_ENV=test
PAYTECH_IPN_URL=https://profiloz.com/api/v1/payments/ipn

STRICT_PDF_READINESS=true
RUN_SEED=true
CRON_SECRET=change-me-cron-secret

# --- Configuration SMTP (Brevo) ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=b236c6001@smtp-brevo.com
SMTP_PASS=votre_cle_smtp_brevo_ici
SMTP_FROM="Profilo'Z <contact@profiloz.com>"
