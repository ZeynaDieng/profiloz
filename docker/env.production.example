# Configuration Profilo'Z Production
# Copier ce fichier en .env.production et modifier les valeurs

# PostgreSQL
POSTGRES_USER=profiloz
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=profiloz

# Redis
REDIS_CACHE_TTL=3600

# JWT
JWT_SECRET=change-me-in-production-use-strong-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=https://yourdomain.com

# Application
APP_URL=http://web:3000
NUXT_PUBLIC_API_BASE_URL=https://yourdomain.com/api/v1
NUXT_PUBLIC_APP_URL=https://yourdomain.com
NUXT_API_INTERNAL_BASE_URL=http://api:3001/api/v1

# PDF Generation
STRICT_PDF_READINESS=true

# Database Seed
RUN_SEED=true

# Cron Jobs
CRON_SECRET=change-me-cron-secret

# Ports
WEB_PORT=3000
API_PORT=3001
UPTIME_KUMA_PORT=3002

# Backups
BACKUP_DIR=/backups
RETENTION_DAYS=7

# Deployments
DEPLOYMENTS_DIR=/deployments
