{
  "name": "@profiloz/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001 --hostname 0.0.0.0",
    "predev": "prisma generate",
    "build": "prisma generate && next build",
    "start": "next start --port 3001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "ocr:scorecard": "tsx src/scripts/ocr-scorecard.ts",
    "ocr:metrics": "tsx src/scripts/ocr-metrics.ts",
    "ocr:benchmark": "tsx src/scripts/ocr-benchmark.ts",
    "ocr:validate-real": "tsx src/scripts/ocr-validate-real.ts",
    "ocr:validate-production": "tsx src/scripts/ocr-validate-production.ts",
    "ocr:generate-samples": "tsx src/scripts/generate-cv-samples.ts",
    "cleanup": "tsx src/scripts/run-cleanup.ts",
    "cleanup:pdf": "tsx src/scripts/run-cleanup.ts --jobs=pdf",
    "cleanup:guest": "tsx src/scripts/run-cleanup.ts --jobs=guest",
    "cleanup:orphan": "tsx src/scripts/run-cleanup.ts --jobs=orphan",
    "clean": "rm -rf .next dist",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "puppeteer browsers install chrome || true"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.80",
    "@prisma/client": "^6.1.0",
    "@profiloz/shared": "workspace:*",
    "@profiloz/validators": "workspace:*",
    "bcryptjs": "^2.4.3",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "next": "^15.1.3",
    "nodemailer": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.10.38",
    "puppeteer": "^24.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tesseract.js": "^6.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.1",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
