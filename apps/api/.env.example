DATABASE_URL="postgresql://profiloz:UN_MOT_DE_PASSE_TRES_FORT@postgres:5432/profiloz"
JWT_SECRET="UNE_CLE_DE_64_CARACTERES"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"
STORAGE_PROVIDER="local"
STORAGE_PERSISTENT_PATH="/app/storage/persistent"
STORAGE_TEMP_PATH="/app/storage/temp"
CORS_ORIGIN="https://profiloz.com"
# URL Nuxt joignable par Puppeteer (Docker : http://web:3000)
APP_URL="http://web:3000"
# URL publique du front pour PayTech (redirections navigateur). En local : http://localhost:3000
PUBLIC_APP_URL="http://localhost:3000"
CRON_SECRET="UNE_AUTRE_CLE"
PORT=3001
REDIS_URL="redis://redis:6379"
REDIS_CACHE_TTL=30
# Optional: path to Chrome/Chromium if Puppeteer's bundled browser is unavailable
# PUPPETEER_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
# PDF generation tuning
# PDF_MAX_CONCURRENT=2
# PDF_BROWSER_IDLE_MS=60000
# PDF_RATE_LIMIT=30
# PDF_RATE_WINDOW_MS=3600000

# --- Paiement PayTech ---
# Clés API depuis le tableau de bord PayTech (Paramètres > API & IPN)
PAYTECH_API_KEY="..."
PAYTECH_API_SECRET="..."
# "test" (sandbox) ou "prod"
PAYTECH_ENV="prod"
# URL IPN publique en HTTPS, joignable par PayTech
PAYTECH_IPN_URL="https://profiloz.com/api/v1/payments/ipn"

# Propriétaire Profilo'Z — promu automatiquement en ADMIN à la connexion
PROFILOZ_OWNER_EMAIL="votre-email@profiloz.com"

# --- Production ---
RUN_SEED=false
STRICT_PDF_READINESS=true

# --- Configuration SMTP (Brevo) ---
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USER="b236c6001@smtp-brevo.com"
SMTP_PASS="votre_cle_smtp_brevo_ici"
SMTP_FROM="Profilo'Z <contact@profiloz.com>"
