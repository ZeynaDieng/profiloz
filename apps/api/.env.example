DATABASE_URL="postgresql://profiloz:profiloz@localhost:5432/profiloz"
JWT_SECRET="change-me-in-production-use-64-char-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
STORAGE_PROVIDER="local"
STORAGE_LOCAL_PATH="./storage"
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"
# URL Nuxt joignable par Puppeteer (dev local : port 3000 ; Docker : http://web:3000)
APP_URL="http://127.0.0.1:3000"
CRON_SECRET="change-me-cron-secret"
PORT=3001
# Optional: path to Chrome/Chromium if Puppeteer's bundled browser is unavailable
# PUPPETEER_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
# PDF generation tuning
# PDF_MAX_CONCURRENT=2
# PDF_BROWSER_IDLE_MS=60000
# PDF_RATE_LIMIT=30
# PDF_RATE_WINDOW_MS=3600000

# --- Paiement PayTech ---
# Clés API depuis le tableau de bord PayTech (Paramètres > API & IPN)
PAYTECH_API_KEY=""
PAYTECH_API_SECRET=""
# "test" (sandbox) ou "prod"
PAYTECH_ENV="test"
# URL IPN publique en HTTPS, joignable par PayTech (utilisez ngrok en local).
# Laisser vide désactive la notification automatique (le crédit ne sera pas ajouté).
# Exemple : https://votre-domaine.com/api/v1/payments/ipn
PAYTECH_IPN_URL=""
