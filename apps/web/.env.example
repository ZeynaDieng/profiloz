NUXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3001/api/v1
NUXT_PUBLIC_APP_URL=http://localhost:3000

# ── SEO ────────────────────────────────────────────────────────────
# URL canonique du site (utilisée pour le sitemap, canonical, OG)
NUXT_PUBLIC_SITE_URL=https://profiloz.com

# ── Analytics & Tracking (laisser vide pour désactiver) ────────────
# Google Analytics 4 Measurement ID (ex: G-XXXXXXXXXX)
NUXT_PUBLIC_GTAG_ID=
# Google Tag Manager Container ID (ex: GTM-XXXXXXX)
NUXT_PUBLIC_GTM_ID=
# Microsoft Clarity Project ID
NUXT_PUBLIC_CLARITY_ID=
# Meta / Facebook Pixel ID
NUXT_PUBLIC_META_PIXEL_ID=
# Google Ads Conversion ID (ex: AW-XXXXXXXXXX)
NUXT_PUBLIC_GOOGLE_ADS_ID=
# Google Search Console verification meta tag
NUXT_PUBLIC_GSC_VERIFICATION=

# ── Docker prod uniquement ─────────────────────────────────────────
# URL API interne pour SSR (/imprimer/cv) et avatars Puppeteer
# NUXT_API_INTERNAL_BASE_URL=http://api:3001/api/v1
